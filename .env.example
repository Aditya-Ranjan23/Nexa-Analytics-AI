# Django
DEBUG=True
DJANGO_SECRET_KEY=change-me-in-production
ALLOWED_HOSTS=127.0.0.1,localhost

# Logging
LOG_LEVEL=INFO

# NVIDIA AI (optional — app falls back when unset)
