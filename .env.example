# ==============================================================================
# Nexa Analytics AI Assistant — Environment Configuration Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.
# ==============================================================================

# ------------------------------------------------------------------------------
# Django core
# ------------------------------------------------------------------------------

# Environment: development | staging | production
DJANGO_ENV=development

# Debug mode (auto-set based on DJANGO_ENV; override here if needed)
DEBUG=True

# SECURITY WARNING: Set a unique 50+ character random string in production.
# Generate: python -c "import secrets; print(secrets.token_urlsafe(64))"
DJANGO_SECRET_KEY=change-me-in-production

# Comma-separated allowed hosts (required in staging/production)
ALLOWED_HOSTS=127.0.0.1,localhost

# ------------------------------------------------------------------------------
# Logging
# ------------------------------------------------------------------------------

LOG_LEVEL=INFO

# ------------------------------------------------------------------------------
# NVIDIA AI (optional — app falls back to local response when unset)
# ------------------------------------------------------------------------------

NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=meta/llama-3.1-70b-instruct

# ------------------------------------------------------------------------------
# Analytics data source
# ------------------------------------------------------------------------------

# csv  → use bundled seed dataset (default, zero-config)
# postgres → read from PostgreSQL (set DATABASES in settings or use dj-database-url)
ANALYTICS_SOURCE=csv
ANALYTICS_TABLE=analytics_sales

# ------------------------------------------------------------------------------
# Upload limits
# ------------------------------------------------------------------------------

# Maximum upload size in megabytes (default: 25 MB)
# Applied to both file uploads and URL-ingested datasets.
MAX_UPLOAD_MB=25

# ------------------------------------------------------------------------------
# Rate limiting (DRF throttle rates)
# Format: <count>/<period>  e.g. 60/minute, 1000/hour, 10000/day
# ------------------------------------------------------------------------------

THROTTLE_ANON_RATE=60/minute
THROTTLE_USER_RATE=120/minute
THROTTLE_CHAT_ANON_RATE=20/minute
THROTTLE_CHAT_USER_RATE=40/minute
THROTTLE_UPLOAD_ANON_RATE=10/minute
THROTTLE_UPLOAD_USER_RATE=20/minute

# ==============================================================================
# Production example (use with DJANGO_SETTINGS_MODULE=config.settings_production)
# ==============================================================================
# DJANGO_ENV=production
# DEBUG=False
# DJANGO_SECRET_KEY=<generate-50+-char-random-string>
# ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com
# LOG_LEVEL=WARNING
# MAX_UPLOAD_MB=25
# THROTTLE_ANON_RATE=30/minute
# THROTTLE_CHAT_ANON_RATE=10/minute
# THROTTLE_UPLOAD_ANON_RATE=5/minute
